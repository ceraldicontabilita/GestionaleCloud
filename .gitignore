# Ceraldi ERP .gitignore

# IDE
.idea/
.vscode/

# Dependencies
node_modules/
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins

# Testing
/coverage

# Production builds
/build
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System files
.DS_Store
*.pem

# Python
__pycache__/
*.pyc
venv/
.venv/

# Archive files
**/*.zip
**/*.tar.gz
*.pack

# Build caches
.cache/
frontend/node_modules/.cache/

# Environment and credential files — non devono MAI finire nel repo
.env
.env.*
*.env
*token.json*
credentials.json
*credentials.json*
*.key
.credentials

# Documenti caricati a runtime — l'app scrive in /tmp/uploads/ (effimero,
# container storage), mai in questa cartella. Non deve mai finire committata:
# ha contenuto dati reali (fatture, verbali, ricevute).
uploads/

# npm lockfile generated by the web session-start hook (yarn.lock is source of truth)
frontend/package-lock.json

# Committed frontend build — Render static site serves this (no build step)
!frontend/dist/
!frontend/dist/**
